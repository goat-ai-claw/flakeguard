{
  "name": "flakeguard",
  "version": "0.1.0",
  "description": "GitHub Actions flaky-test triage for small teams",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "lint": "tsc --noEmit",
    "test": "jest --verbose",
    "demo:cross-run": "npm run build && node scripts/demo-cross-run.cjs"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "fast-xml-parser": "^5.3.0",
    "glob": "^11.0.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.7.2",
    "@vercel/ncc": "^0.38.4",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "private": true
}
